  <dcat:Dataset rdf:about="https://www.idee.es/csw-codsi-idee/srv/api/records/spaignPNOA2024">

    <adms:identifier rdf:resource="https://www.idee.es/csw-codsi-idee/srv/spa/catalog.search#/metadata/spaignPNOA2024"/>
    <dcat:distribution rdf:resource="https://www.idee.es/csw-codsi-idee/srv/api/records/spaignPNOA2024/formatters/html"/>
    <dcat:distribution rdf:resource="https://www.idee.es/csw-codsi-idee/srv/api/records/spaignPNOA2024/formatters/xml"/>
    <dcat:keyword xml:lang="es">Ortoimágenes</dcat:keyword>
    <dcat:keyword xml:lang="es">High-value dataset</dcat:keyword>
    <dcat:keyword xml:lang="es">Earth observation and environment</dcat:keyword>
    <dcat:keyword xml:lang="es">Orthoimagery</dcat:keyword>
    <dcat:keyword xml:lang="es">Nacional</dcat:keyword>
    <dcat:keyword xml:lang="es">Sistema Cartográfico Nacional</dcat:keyword>
    <dcat:keyword xml:lang="es">España</dcat:keyword>
    <dcatap:applicableLegislation rdf:resource="http://data.europa.eu/eli/reg_impl/2023/138/oj"/>
    <dcatap:applicableLegislation rdf:resource="http://data.europa.eu/eli/reg/2008/1205/oj"/>
    <dcatap:hvdCategory rdf:resource="http://data.europa.eu/bna/c_dd313021"/>
    <dct:accessRights rdf:resource="http://publications.europa.eu/resource/authority/access-right/PUBLIC"/>
    <dct:conformsTo rdf:resource="https://datosgobes.github.io/DCAT-AP-ES"/>
    <dct:description xml:lang="es">Ortofotografías aéreas digitales del Plan Nacional de Ortofotografía Aérea del vuelo de 2024 (PNOA 2024) de Castilla-La Mancha, Aragón, Illes Balears y Comunitat Valenciana con una resolución de 25 cm y Canarias con una resolución de 20 cm.
Los mosaicos se han obtenido a partir de las ortofotos definitivas más recientes.
Las fechas de creación de cada mosaico son:
Castilla-La Mancha norte: marzo 2025
Castilla-La Mancha sur: junio 2025
Illes Balears: abril 2025
Aragón Sur: mayo 2025
Aragón Norte: agosto 2025
Canarias: octubre 2025
Comunitat Valenciana: noviembre 2025</dct:description>
    <dct:description xml:lang="en">Digital aerial orthophotographs from the National Aerial Orthophotography Plan for the 2024 flight (PNOA 2024) of Castilla-La Mancha, Aragon, Balearic Islands and Valencian Community with a resolution of 25 cm.
The mosaics were obtained from the most recent definitive orthophotos and the Canary Islands with a resolution of 20 cm.
The dates of creation of each mosaic are:
Northern Castile-La Mancha: March 2025
Southern Castile-La Mancha: June 2025
Balearic Islands: April 2025
Southern Aragon: May 2025
Northern Aragon: August 2025
Canary Islands: October 2025
Valencian Community: November 2025</dct:description>
    <dct:identifier>spaignPNOA2024</dct:identifier>
    <dct:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-01T00:00:00+01:00</dct:issued>
    <dct:language rdf:resource="http://publications.europa.eu/resource/authority/language/SPA"/>
    <dct:spatial>
      <dct:Location>
        <dcat:bbox rdf:datatype="http://www.opengis.net/ont/geosparql#wktLiteral">POLYGON((-7.07 39.87, -1.78 39.87, -1.78 43.24, -7.07 43.24, -7.07 39.87))</dcat:bbox>
      </dct:Location>
    </dct:spatial>
    <dct:title xml:lang="es">Ortofotos PNOA Anual de 2024 (Máxima actualidad)</dct:title>
    <dct:title xml:lang="en">Annual aerial orthophotographs of PNOA 2024 (Most up-to-date)</dct:title>
    <dct:type rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/ResourceType/dataset"/>
