          "@type": "foaf:Agent",
          "dct:identifier": "http://datos.gob.es/recurso/sector-publico/org/Organismo/E0DAT0001",
          "dct:type": {
            "@id": "http://purl.org/adms/publishertype/NationalAuthority"
          },
          "foaf:name": [
            {
              "@value": "Ministerio de Defensa",
              "@language": "es"
            }
          ]
        }
      ],
      "dct:title": {
        "@value": "Catálogo industria española de Defensa. Sexta edición",
        "@language": "es"
      },
      "dct:description": {
        "@value": "Este catálogo nació para dar respuesta a una necesidad identificada por la Oficina de Apoyo Exterior (OFICAEX) de la Subdirección General de Relaciones Internacionales de la DGAM: disponer de una publicación oficial, pública y gratuita, que facilitase el dar a conocer y promover en los mercados exteriores las capacidades de la industria española de defensa.  \nDicha publicación debería ofrecer, en un formato amigable y cómodo en su manejo por los usuarios, información contrastada, sin clasificar, de las capacidades de nuestra industria, facilitándose así su más amplia difusión. Otro requisito esencial era el de su imparcialidad y apertura a toda la industria del sector.",
        "@language": "es"
      },
      "dct:accessRights": {
        "@id": "http://publications.europa.eu/resource/authority/access-right/PUBLIC"
      },
      "dct:issued": [
        {
          "@value": "2025-05-25T00:00:00+01:00",
          "@type": "http://www.w3.org/2001/XMLSchema#dateTime"
        }
      ],
