<?xml version="1.0" encoding="utf-8" ?>
<rdf:RDF xmlns:rdf="http://www.w3.org"
         xmlns:dcat="http://www.w3.org"
         xmlns:dcatap="http://data.europa.eu"
         xmlns:dct="http://purl.org"
         xmlns:foaf="http://xmlns.com"
         xmlns:vcard="http://www.w3.org">

  <dcat:Catalog rdf:about="http://dcat-ap-es.ejemplo.org">
    <dct:title xml:lang="es">Catálogo de Datos Abiertos</dct:title>
    <dct:description xml:lang="es">Catálogo de Datos Abiertos que sirve de ejemplo en DCAT-AP-ES.</dct:description>
    <foaf:homepage rdf:resource="http://dcat-ap-es.ejemplo.org"/>
    
    <dct:publisher rdf:resource="http://datos.gob.es"/>
    
    <dcat:themeTaxonomy rdf:resource="http://datos.gob.es/kos/sector-publico/sector"/>
    <dct:issued rdf:datatype="http://www.w3.org">2025-01-01T09:00:00+01:00</dct:issued>
    <dct:modified rdf:datatype="http://www.w3.org">2025-01-02T12:00:00+01:00</dct:modified>
    <dct:language rdf:resource="http://publications.europa.eu/resource/authority/language/SPA"/>
    <dct:spatial rdf:resource="http://datos.gob.es/recurso/sector-publico/territorio/Pais/España"/>
    <dct:license rdf:resource="http://publications.europa.eu/resource/authority/licence/CC_BY_4_0"/>

    <dct:creator rdf:resource="http://otro.es"/>

    <dcat:dataset>
      <dcat:Dataset rdf:about="http://dcat-ap-es.ejemplo.org">
        <dct:title xml:lang="es">Dataset de ejemplo</dct:title>
        
        <dct:publisher rdf:resource="http://otro.es"/>
        <dcat:theme rdf:resource="http://datos.gob.es/kos/sector-publico/sector/medio-ambiente"/>
        <dcat:keyword xml:lang="es">estadísticas</dcat:keyword>
        <dct:spatial rdf:resource="http://datos.gob.es/recurso/sector-publico/territorio/Pais/España"/>

        <dcat:contactPoint>
          <vcard:Organization rdf:about="http://dcat-ap-es.ejemplo.org">
            <vcard:organization-name xml:lang="es">Organismo</vcard:organization-name>
            <vcard:fn xml:lang="es">Oficina del dato</vcard:fn>
            <vcard:hasURL rdf:resource="http://dcat-ap-es.ejemplo.org"/>
            <vcard:hasUID rdf:resource="http://datos.gob.es"/>
            <vcard:hasEmail rdf:resource="mailto:info-contacto@dcat-ap-es.ejemplo.org"/>
          </vcard:Organization>
        </dcat:contactPoint>

        <dct:temporal>
          <dct:PeriodOfTime>
            <dcat:startDate rdf:datatype="http://www.w3.org">2021-01-01T00:00:00Z</dcat:startDate>
            <dcat:endDate rdf:datatype="http://www.w3.org">2025-01-01T00:00:00Z</dcat:endDate>
          </dct:PeriodOfTime>
        </dct:temporal>
		
        <dcat:distribution>
          <dcat:Distribution rdf:about="http://dcat-ap-es.ejemplo.orgdistribucion/dataset-CSV">
            <dct:title xml:lang="es">Distribucion CSV</dct:title>
            <dcat:accessURL rdf:resource="http://dcat-ap-es.ejemplo.orgfiles/dataset-ejemplo-1.CSV"/>
            <dct:format rdf:resource="http://publications.europa.eu/resource/authority/file-type/CSV"/> 
          </dcat:Distribution>
        </dcat:distribution>
      </dcat:Dataset>
    </dcat:dataset>

    <!-- DEFINICIÓN EXPLÍCITA DE LOS AGENTES DENTRO DEL CATÁLOGO -->
    <foaf:Agent rdf:about="http://datos.gob.es">
      <foaf:name xml:lang="es">Nombre Oficial del Organismo 1</foaf:name>
      <dct:type rdf:resource="http://purl.org"/>
    </foaf:Agent>

    <foaf:Agent rdf:about="http://otro.es">
      <foaf:name xml:lang="es">Otro</foaf:name>
      <dct:type rdf:resource="http://purl.org"/>
    </foaf:Agent>

  </dcat:Catalog>
</rdf:RDF>