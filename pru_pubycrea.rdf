         xmlns:spdx="http://spdx.org/rdf/terms#"
         xmlns:odrl="http://www.w3.org/ns/odrl/2/">

  <dcat:Catalog rdf:about="http://dcat-ap-es.ejemplo.org">
    <dct:title xml:lang="es">Catálogo de Datos Abiertos</dct:title>
    <dct:description xml:lang="es">Catálogo de Datos Abiertos que sirve de ejemplo en DCAT-AP-ES.</dct:description>
    <foaf:homepage rdf:resource="http://dcat-ap-es.ejemplo.org/home"/>
    
    <dct:publisher rdf:resource="http://datos.gob.es/recurso/sector-publico/org/Organismo/LA0002304"/>
    
    <dcat:themeTaxonomy rdf:resource="http://datos.gob.es/kos/sector-publico/sector"/>
    <dct:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-01-01T09:00:00+01:00</dct:issued>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-01-02T12:00:00+01:00</dct:modified>
    <dct:language rdf:resource="http://publications.europa.eu/resource/authority/language/SPA"/>
    <dct:spatial rdf:resource="http://datos.gob.es/recurso/sector-publico/territorio/Pais/España"/>
    <dct:license rdf:resource="http://publications.europa.eu/resource/authority/licence/CC_BY_4_0"/>




    <dcat:dataset>
      <dcat:Dataset rdf:about="http://dcat-ap-es.ejemplo.org/dataset">
        <dct:title xml:lang="es">Dataset de ejemplo EEE Auditorio</dct:title>
        <dct:description xml:lang="es">Descripción de un dataset de ejemplo EEE</dct:description>
        <dct:publisher rdf:resource="http://datos.gob.es/recurso/sector-publico/org/Organismo/LA0002304"/>
        <dcat:theme rdf:resource="http://datos.gob.es/kos/sector-publico/sector/medio-ambiente"/>
        <dcat:keyword xml:lang="es">estadísticas</dcat:keyword>
        <dct:spatial rdf:resource="http://datos.gob.es/recurso/sector-publico/territorio/Pais/España"/>
        <dcat:contactPoint>
          <vcard:Organization>
            <vcard:organization-name xml:lang="es">OrganismoContacto</vcard:organization-name>
            <vcard:fn xml:lang="es">Oficina del dato</vcard:fn>
            <vcard:hasURL rdf:resource="http://dcat-ap-es.ejemplo.org/oficinadeldato"/>
            <vcard:hasUID rdf:resource="http://datos.gob.es/recurso/sector-publico/org/Organismo/E0DAT0001"/>
            <vcard:hasEmail rdf:resource="mailto:info-contacto@dcat-ap-es.ejemplo.org"/>
            <vcard:hasTelephone rdf:resource="tel:.+3491222222"/>
          </vcard:Organization>
        </dcat:contactPoint>

    

        <dcat:distribution>
          <dcat:Distribution rdf:about="http://dcat-ap-es.ejemplo.org/distribucion/dataset-CSV">
            <dct:title xml:lang="es">Distribucion CSV</dct:title>
            <dct:description xml:lang="es">Descripción de distribucion csv</dct:description>
            <dcat:accessURL rdf:resource="http://dcat-ap-es.ejemplo.org/files/dataset-ejemplo-1.CSV"/>
            <dct:format rdf:resource="http://publications.europa.eu/resource/authority/file-type/CSV"/> 
            <dct:license rdf:resource="http://publications.europa.eu/resource/authority/licence/CC_BY_4_0"/>
            <dcatap:applicableLegislation rdf:resource="http://data.europa.eu/eli/dir/2007/2/2019-06-26"/>
            <dcatap:availability rdf:resource="http://publications.europa.eu/resource/authority/planned-availability/STABLE"/>
          </dcat:Distribution>
        </dcat:distribution>

        <dcat:distribution>
          <dcat:Distribution rdf:about="http://dcat-ap-es.ejemplo.org/distribucion/dataset-xxx">
            <dct:title xml:lang="es">Distribucion prueba formato inventado</dct:title>
            
            <dct:format rdf:resource="http://publications.europa.eu/resource/authority/file-type/formatEUesther"/>
            <dcat:mediaType rdf:resource="https://www.iana.org/assignments/media-types/application/bufr"/> 
            
            <dct:description xml:lang="es">Descripción de distribucion prueba formato inventado</dct:description>
            <dcat:accessURL rdf:resource="http://dcat-ap-es.ejemplo.org/files/dataset-ejemplo-1.pru"/>
            <dct:license rdf:resource="http://publications.europa.eu/resource/authority/licence/CC_BY_4_0"/>
            <dcatap:applicableLegislation rdf:resource="http://data.europa.eu/eli/dir/2007/2/2019-06-26"/>
            <dcatap:availability rdf:resource="http://publications.europa.eu/resource/authority/planned-availability/STABLE"/>
          </dcat:Distribution>
        </dcat:distribution>

        <dcat:distribution>
          <dcat:Distribution rdf:about="http://dcat-ap-es.ejemplo.org/distribucion/dataset-COG1">
            <dct:title xml:lang="es">Distribucion prueba formato COG</dct:title>
            
              <dct:format>
                <dct:IMT>
                  <rdf:value>image/tiff; application=geotiff; profile=cloud-optimized</rdf:value>
                  <rdfs:label>COG</rdfs:label>
                </dct:IMT>
              </dct:format>
            <dcat:mediaType rdf:resource="https://www.iana.org/assignments/media-types/image/tiff"/> 
            
            <dct:description xml:lang="es">Descripción de distribucion prueba formato COG</dct:description>
            <dcat:accessURL rdf:resource="http://dcat-ap-es.ejemplo.org/files/dataset-ejemplo-1.pru"/>
            <dct:license rdf:resource="http://publications.europa.eu/resource/authority/licence/CC_BY_4_0"/>
            <dcatap:applicableLegislation rdf:resource="http://data.europa.eu/eli/dir/2007/2/2019-06-26"/>
            <dcatap:availability rdf:resource="http://publications.europa.eu/resource/authority/planned-availability/STABLE"/>
          </dcat:Distribution>
        </dcat:distribution>

          <dcat:distribution>
          <dcat:Distribution rdf:about="http://dcat-ap-es.ejemplo.org/distribucion/dataset-COG2">
            <dct:title xml:lang="es">Distribucion prueba formato COG</dct:title>
            
              <dct:format>
                <dct:IMT>
                  <rdf:value>COG_value</rdf:value>
                  <rdfs:label>COG_label</rdfs:label>
                </dct:IMT>
              </dct:format>
            <dcat:mediaType rdf:resource="https://www.iana.org/assignments/media-types/image/tiff"/> 
            
            <dct:description xml:lang="es">Descripción de distribucion prueba formato COG</dct:description>
            <dcat:accessURL rdf:resource="http://dcat-ap-es.ejemplo.org/files/dataset-ejemplo-1.pru"/>
            <dct:license rdf:resource="http://publications.europa.eu/resource/authority/licence/CC_BY_4_0"/>
            <dcatap:applicableLegislation rdf:resource="http://data.europa.eu/eli/dir/2007/2/2019-06-26"/>
            <dcatap:availability rdf:resource="http://publications.europa.eu/resource/authority/planned-availability/STABLE"/>
          </dcat:Distribution>
        </dcat:distribution>


      </dcat:Dataset>
    </dcat:dataset>

