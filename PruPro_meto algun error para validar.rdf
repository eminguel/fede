    <dcat:dataset>
      <dcat:Dataset rdf:about="https://prees-datalab.ine.es/dataset/ioe301881">
        <dct:title xml:lang="es">Encuesta Anual de Coste Laboral. Cuentas de cotización</dct:title>
        <dct:description xml:lang="en">Estimation of annual labour costs and their components. The Annual Labour Cost Survey aims to collect labour cost items not recorded in the quarterly questionnaires or included in aggregated form from the previous year</dct:description>
        <dct:description xml:lang="es">Estimación del coste anual de la mano de obra y sus componentes. la Encuesta Anual de Coste Laboral  tiene por objetivo recoger las partidas de coste laboral no registradas en los cuestionarios trimestrales o incluidas de forma agregada del año inmediatamente anterior</dct:description>
        <dcat:landingPage rdf:resource="https://prees-datalab.ine.es/ckan/dataset/ioe301881" />
